{
  "position": "top",
  "margin-top": 6,
  "margin-bottom": 0,
  "margin-left": 8,
  "margin-right": 8,
  "spacing": 0,
  "fixed-center": true,
  "modules-left": [
    "custom/arch",
    "hyprland/workspaces",
    "custom/separator",
    "mpris",
  ],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/screenrecord",
    "tray",
    "memory",
    "cpu",
    "network",
    "battery",
  ],

  // ─── Custom decorators ───
  "custom/arch": {
    "format": "\uf303",
    "tooltip": false,
  },
  "custom/separator": {
    "format": " ",
    "tooltip": false,
  },

  // ─── Screen Recording ───
  // "custom/screenrecord": {
  //   "format": "{}",
  //   "return-type": "json",
  //   "interval": "once",
  //   "signal": 8,
  //   "exec": "~/.config/waybar/scripts/screenrecord-status.sh",
  //   "on-click": "~/.local/bin/omarchy-cmd-screenrecord",
  //   "on-click-right": "~/.local/bin/omarchy-cmd-screenrecord --with-desktop-audio",
  //   "on-click-middle": "~/.local/bin/omarchy-cmd-screenrecord --with-webcam",
  //   "tooltip": true,
  // },

  // ─── Clock ───
  "clock": {
    "interval": 1,
    "format": "{:%H:%M}",
    "format-alt": "{:%A  ·  %d %B %Y}",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>",
  },

  // ─── Workspaces ───
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "󰮯",
      "default": "󰊠",
      "empty": "󰑊",
    },
    "persistent-workspaces": {
      "*": 5,
    },
  },

  // ─── Tray ───
  "tray": {
    "icon-size": 13,
    "spacing": 8,
  },

  // ─── System ───
  "cpu": {
    "interval": 3,
    "format": "󰻠 {usage}%",
    "on-click": "xdg-terminal-exec btop",
  },
  "memory": {
    "interval": 5,
    "format": "󰍛 {percentage}%",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
    "on-click": "xdg-terminal-exec btop",
  },

  // ─── Network ───
  "network": {
    "format-wifi": "󰖩 {essid}",
    "format-ethernet": "󰈀 Ethernet",
    "format-disconnected": "󰖪 Off",
    "tooltip-format-wifi": "  {essid}\n󰩟  {ipaddr}\n󰁞  {bandwidthUpBits}\n󰁆  {bandwidthDownBits}",
    "interval": 5,
    "on-click": "omarchy-launch-wifi",
  },

  // ─── Battery ───
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "󱐋 {capacity}%",
    "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "tooltip-format": "{timeTo}\n{power:.1f}W",
    "interval": 15,
    "states": {
      "warning": 30,
      "critical": 15,
    },
  },

  // ─── Media ───
  "mpris": {
    "format": "{player_icon}  {dynamic}",
    "format-paused": "{player_icon}  {dynamic}",
    "dynamic-order": ["title", "artist"],
    "dynamic-separator": "  ·  ",
    "dynamic-len": 35,
    "player-icons": {
      "default": "󰎆",
      "spotify": "󰓇",
      "firefox": "󰈹",
      "chromium": "󰊯",
      "vlc": "󰕼",
      "mpv": "󰐍",
    },
    "status-icons": {
      "playing": "",
      "paused": "󰏤",
      "stopped": "󰓛",
    },
    "tooltip-format": "{player_icon}  {title}\n  {artist}\n󰀥  {album}",
    "ignored-players": ["playerctld"],
  },
}
